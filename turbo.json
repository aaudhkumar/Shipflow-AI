{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": [
    "DATABASE_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_API_KEY",
    "BETTER_AUTH_URL",
    "GOOGLE_OAUTH_CLIENT_ID",
    "GOOGLE_OAUTH_CLIENT_SECRET",
    "RAZORPAY_KEY_ID",
    "RAZORPAY_KEY_SECRET",
    "OPENAI_API_KEY",
    "GEMINI_API_KEY",
    "OPENROUTER_API_KEY",
    "INNGEST_EVENT_KEY",
    "INNGEST_SIGNING_KEY",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "SESSION_SECRET",
    "APPROVAL_SECRET",
    "CORS_ALLOWED_ORIGINS",
    "PORT",
    "NODE_ENV",
    "BASE_URL",
    "GOOGLE_OAUTH_REDIRECT_URI",
    "PINECONE_API_KEY",
    "PINECONE_INDEX",
    "DEPLOYMENT_WEBHOOK_SECRET",
    "INVITATION_SECRET",
    "RAZORPAY_PRO_PLAN_ID",
    "RAZORPAY_ENTERPRISE_PLAN_ID",
    "RESEND_API_KEY",
    "RESEND_FROM_EMAIL",
    "NEXT_PUBLIC_*"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {},
    "db:migrate": {}
  }
}
